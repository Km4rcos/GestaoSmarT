<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smart.controller.RelatorioGraficoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Relatório Periódico Consolidado" textFill="#1F2937">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>
        <HBox HBox.hgrow="ALWAYS" />
        <Button onAction="#voltar" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #6B7280; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 5px;" text="Voltar" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15px; -fx-background-radius: 5; -fx-border-color: #D1D5DB; -fx-border-radius: 5;">
        <VBox spacing="5.0">
            <Label text="Data Inicial:" textFill="#374151"><font><Font name="System Bold" size="12.0" /></font></Label>
            <DatePicker fx:id="campoDataInicio" prefWidth="130.0" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Data Final:" textFill="#374151"><font><Font name="System Bold" size="12.0" /></font></Label>
            <DatePicker fx:id="campoDataFim" prefWidth="130.0" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Valor Mínimo (R$):" textFill="#374151"><font><Font name="System Bold" size="12.0" /></font></Label>
            <TextField fx:id="campoValorMin" prefWidth="110.0" promptText="Ex: 0.0" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Valor Máximo (R$):" textFill="#374151"><font><Font name="System Bold" size="12.0" /></font></Label>
            <TextField fx:id="campoValorMax" prefWidth="110.0" promptText="Ex: 5000.0" />
        </VBox>
        
        <VBox alignment="BOTTOM_CENTER">
            <Button onAction="#processarRelatorio" prefHeight="25.0" prefWidth="150.0" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 5px;" text="Gerar Visualização" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER" style="-fx-background-color: #111827; -fx-padding: 15px; -fx-background-radius: 5;">
        <Label fx:id="labelTotal" text="TOTAL NO PERÍODO: R$ 0.00" textFill="#10B981">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
    </HBox>

    <BarChart fx:id="graficoCompras" prefHeight="350.0" animated="false" legendVisible="false">
        <xAxis>
            <CategoryAxis label="Descrição da Compra" side="BOTTOM" />
        </xAxis>
        <yAxis>
            <NumberAxis label="Valor Total (R$)" side="LEFT" />
        </yAxis>
    </BarChart>
</VBox>