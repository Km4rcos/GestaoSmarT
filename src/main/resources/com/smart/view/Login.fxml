<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smart.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Gestão SmarT" textFill="#1F2937">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>
    <Label text="Faça login para continuar" textFill="#6B7280">
        <font>
            <Font size="14.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <VBox spacing="5.0" maxWidth="250.0">
        <Label text="E-mail:" textFill="#374151">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <TextField fx:id="campoEmail" promptText="Digite seu e-mail" style="-fx-padding: 8px; -fx-background-radius: 5;" />
    </VBox>

    <VBox spacing="5.0" maxWidth="250.0">
        <Label text="Senha:" textFill="#374151">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <PasswordField fx:id="campoSenha" promptText="Digite sua senha" style="-fx-padding: 8px; -fx-background-radius: 5;" />
    </VBox>

    <Button fx:id="botaoEntrar" onAction="#fazerLogin" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Entrar">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Button>

    <Hyperlink onAction="#abrirTelaCadastro" style="-fx-text-fill: #2563EB; -fx-border-color: transparent;" text="Não tem conta? Cadastre-se">
        <font>
            <Font size="13.0" />
        </font>
    </Hyperlink>
</VBox>