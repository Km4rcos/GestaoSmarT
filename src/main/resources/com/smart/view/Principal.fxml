<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="painelPrincipal" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smart.controller.PrincipalController">
    
    <top>
        <HBox alignment="CENTER" spacing="0.0" style="-fx-background-color: #2563EB; -fx-border-color: #374151; -fx-border-width: 0 0 1 0; -fx-padding: 0px;">
            
            <Button onAction="#exibirRelatorioCompras" prefHeight="70.0" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 0; -fx-border-color: #374151; -fx-border-width: 0 1 0 0; -fx-padding: 10px;">
                <graphic>
                    <VBox alignment="CENTER">
                        <Label text="DASHBOARD GERAL" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Painel de Listagem" textFill="#ffffff" style="-fx-font-size: 11px;"/>
                    </VBox>
                </graphic>
            </Button>

            <Button onAction="#exibirCadastroCompra" prefHeight="70.0" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 0; -fx-border-color: #374151; -fx-border-width: 0 1 0 0; -fx-padding: 10px;">
                <graphic>
                    <VBox alignment="CENTER">
                        <Label text="NOVA COMPRA" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Lançar Nota Fiscal" textFill="#ffffff" style="-fx-font-size: 11px;"/>
                    </VBox>
                </graphic>
            </Button>

            <Button onAction="#abrirRelatorioGrafico" prefHeight="70.0" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 0; -fx-border-color: #374151; -fx-border-width: 0 1 0 0; -fx-padding: 10px;">
                <graphic>
                    <VBox alignment="CENTER">
                        <Label text="RELATÓRIO GRÁFICO" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Filtros e Evolução" textFill="#ffffff" style="-fx-font-size: 11px;"/>
                    </VBox>
                </graphic>
            </Button>
            
            <Button onAction="#fazerLogout" prefHeight="70.0" prefWidth="150.0" HBox.hgrow="NEVER" style="-fx-background-color: #eb2525; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 0; -fx-padding: 10px;">
                <graphic>
                    <VBox alignment="CENTER">
                        <Label text="SAIR" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Fechar Sistema" textFill="#ffffff" style="-fx-font-size: 11px;"/>
                    </VBox>
                </graphic>
            </Button>
        </HBox>
    </top>

    <center>
        <VBox spacing="15.0">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            
            <Label text="Painel Geral de Compras" textFill="#1F2937">
                <font>
                    <Font name="System Bold" size="22.0" />
                </font>
            </Label>
            
            <Label text="Dica: Dê dois cliques rápidos sobre uma compra para gerenciar seus produtos." textFill="#4B5563">
                <font>
                    <Font size="13.0" />
                </font>
            </Label>

            <TableView fx:id="tabelaCompras" prefHeight="400.0" prefWidth="850.0" style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-background-color: white; -fx-border-color: #D1D5DB;">
                <columns>
                    <TableColumn fx:id="colunaDescricao" prefWidth="845.0" text="Descrição da Compra" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT">
                <Button onAction="#removerCompra" prefHeight="35.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8px 15px;" text="🗑 EXCLUIR COMPRA SELECIONADA" />
            </HBox>
        </VBox>
    </center>
</BorderPane>