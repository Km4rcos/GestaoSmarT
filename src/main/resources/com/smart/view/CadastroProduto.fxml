<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smart.controller.CadastroProdutoController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" prefWidth="850.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Produtos Cadastrados" textFill="#1F2937">
                <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            <Label fx:id="labelIdentificador" text="Compra: Carregando..." textFill="#2563EB">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
        </VBox>
        <Button onAction="#voltar" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #6B7280; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 5px;" text="Voltar ao Painel" />
    </HBox>

    <TableView fx:id="tabelaProdutos" prefHeight="260.0" prefWidth="850.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #D1D5DB; -fx-border-radius: 5;">
        <columns>
            <TableColumn fx:id="colunaNome" prefWidth="350.0" text="Nome do Item" />
            <TableColumn fx:id="colunaValor" prefWidth="200.0" text="Valor Unitário (R$)" />
            <TableColumn fx:id="colunaTipo" prefWidth="295.0" text="Tipo / Categoria" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" prefWidth="850.0">
        <Button onAction="#removerProduto" prefHeight="30.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 5px 15px;" text="🗑 Remover Item Selecionado" />
    </HBox>

    <Label text="Inserir Item na Lista de Compras:" textFill="#374151" alignment="CENTER_LEFT" prefWidth="850.0">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>

    <HBox spacing="15.0" alignment="BOTTOM_CENTER" prefWidth="850.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Nome do Produto:" textFill="#4B5563"><font><Font name="System Bold" size="11.0" /></font></Label>
            <TextField fx:id="campoNome" promptText="Ex: Arroz Tio Urbano" style="-fx-padding: 8px; -fx-background-radius: 5;" />
        </VBox>

        <VBox spacing="4.0" prefWidth="150.0">
            <Label text="Valor (R$):" textFill="#4B5563"><font><Font name="System Bold" size="11.0" /></font></Label>
            <TextField fx:id="campoValor" promptText="Ex: 24.50" style="-fx-padding: 8px; -fx-background-radius: 5;" />
        </VBox>

        <VBox spacing="4.0" prefWidth="200.0">
            <Label text="Tipo / Categoria:" textFill="#4B5563"><font><Font name="System Bold" size="11.0" /></font></Label>
            <TextField fx:id="campoTipo" promptText="Ex: Alimentos" style="-fx-padding: 8px; -fx-background-radius: 5;" />
        </VBox>

        <Button onAction="#adicionarProdutoItem" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 5px;" text="Adicionar Produto" />
    </HBox>
</VBox>