<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smart.controller.CadastroCompraController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Cadastrar Nova Compra" textFill="#1F2937">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>
    <Label text="Insira os dados gerais da nota fiscal" textFill="#6B7280">
        <font>
            <Font size="14.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Nota Fiscal:" textFill="#374151">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <TextField fx:id="campoNotaFiscal" promptText="Ex: NF-9923" style="-fx-padding: 8px; -fx-background-radius: 5;" />
    </VBox>

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Descrição Sumária:" textFill="#374151">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <TextField fx:id="campoDescricao" promptText="Ex: Compra de suprimentos de TI" style="-fx-padding: 8px; -fx-background-radius: 5;" />
    </VBox>

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Data da Compra:" textFill="#374151">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <DatePicker fx:id="campoData" prefHeight="38.0" prefWidth="300.0" promptText="Selecione a data" style="-fx-background-radius: 5;" />
    </VBox>

    <Button fx:id="botaoSalvar" onAction="#salvarCompra" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Salvar Compra">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
        <VBox.margin>
            <Insets top="15.0" />
        </VBox.margin>
    </Button>
</VBox>